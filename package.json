{
  "name": "memopad",
  "displayName": "Memopad",
  "description": "Dead simple notes in VS Code. Plain text, local, no lock-in. Prompts, snippets, whatever you need.",
  "version": "1.0.9",
  "publisher": "gundurraga",
  "icon": "logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/gundurraga/memopad"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "notes",
    "prompts",
    "snippets",
    "sidebar",
    "local",
    "plain-text",
    "ai-prompts",
    "notepad",
    "memo"
  ],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "memopad",
          "title": "Memopad",
          "icon": "$(note)"
        }
      ]
    },
    "views": {
      "memopad": [
        {
          "id": "memopadNotes",
          "name": "Notes",
          "canMoveViews": true
        }
      ]
    },
    "commands": [
      {
        "command": "memopad.addNote",
        "title": "Add Note",
        "icon": "$(add)"
      },
      {
        "command": "memopad.addFolder",
        "title": "Add Folder",
        "icon": "$(new-folder)"
      },
      {
        "command": "memopad.copyNote",
        "title": "Copy Note",
        "icon": "$(copy)"
      },
      {
        "command": "memopad.deleteItem",
        "title": "Delete",
        "icon": "$(trash)"
      },
      {
        "command": "memopad.renameItem",
        "title": "Rename",
        "icon": "$(edit)"
      },
      {
        "command": "memopad.search",
        "title": "Search Notes",
        "icon": "$(search)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "memopad.search",
          "when": "view == memopadNotes",
          "group": "navigation@1"
        },
        {
          "command": "memopad.addNote",
          "when": "view == memopadNotes",
          "group": "navigation@2"
        },
        {
          "command": "memopad.addFolder",
          "when": "view == memopadNotes",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "memopad.addNote",
          "when": "view == memopadNotes && viewItem == folder"
        },
        {
          "command": "memopad.addFolder",
          "when": "view == memopadNotes && viewItem == folder"
        },
        {
          "command": "memopad.copyNote",
          "when": "view == memopadNotes && viewItem == note",
          "group": "inline"
        },
        {
          "command": "memopad.renameItem",
          "when": "view == memopadNotes"
        },
        {
          "command": "memopad.deleteItem",
          "when": "view == memopadNotes"
        }
      ]
    }
  }
}
