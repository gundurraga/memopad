{
  "name": "memopad",
  "displayName": "Memopad",
  "description": "Save and organize notes in the sidebar for quick access",
  "version": "0.0.4",
  "publisher": "gundurraga",
  "icon": "logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/gundurraga/memopad"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "notes",
    "memo",
    "snippets",
    "clipboard",
    "prompts"
  ],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "memopad",
          "title": "Memopad",
          "icon": "$(note)"
        }
      ]
    },
    "views": {
      "memopad": [
        {
          "id": "memopadNotes",
          "name": "Notes",
          "canMoveViews": true
        }
      ]
    },
    "commands": [
      {
        "command": "memopad.addNote",
        "title": "Add Note",
        "icon": "$(add)"
      },
      {
        "command": "memopad.addFolder",
        "title": "Add Folder",
        "icon": "$(new-folder)"
      },
      {
        "command": "memopad.copyNote",
        "title": "Copy Note",
        "icon": "$(copy)"
      },
      {
        "command": "memopad.deleteItem",
        "title": "Delete",
        "icon": "$(trash)"
      },
      {
        "command": "memopad.renameItem",
        "title": "Rename",
        "icon": "$(edit)"
      },
      {
        "command": "memopad.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "memopad.addNote",
          "when": "view == memopadNotes",
          "group": "navigation@1"
        },
        {
          "command": "memopad.addFolder",
          "when": "view == memopadNotes",
          "group": "navigation@2"
        },
        {
          "command": "memopad.refresh",
          "when": "view == memopadNotes",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "memopad.addNote",
          "when": "view == memopadNotes && viewItem == folder"
        },
        {
          "command": "memopad.addFolder",
          "when": "view == memopadNotes && viewItem == folder"
        },
        {
          "command": "memopad.copyNote",
          "when": "view == memopadNotes && viewItem == note",
          "group": "inline"
        },
        {
          "command": "memopad.renameItem",
          "when": "view == memopadNotes"
        },
        {
          "command": "memopad.deleteItem",
          "when": "view == memopadNotes"
        }
      ]
    }
  }
}
